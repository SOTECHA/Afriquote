# ══════════════════════════════════════════════════════════════
# AfriQuote — Environment Variables
# Copy to .env for local dev. On Railway, set these in the
# Railway dashboard under Variables.
# ══════════════════════════════════════════════════════════════

# ── Server ─────────────────────────────────────────────────────
NODE_ENV=production
PORT=4000
# HOST is always 0.0.0.0 on Railway (set in server.js)

# ── Security ────────────────────────────────────────────────────
# REQUIRED: Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=REPLACE_WITH_64_CHAR_RANDOM_HEX_STRING
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=REPLACE_WITH_DIFFERENT_64_CHAR_RANDOM_HEX_STRING
JWT_REFRESH_EXPIRES_IN=30d

# ── CORS ────────────────────────────────────────────────────────
# Your Railway app URL — e.g. https://afriquote-production.up.railway.app
ALLOWED_ORIGINS=https://yourdomain.com,https://yourapp.up.railway.app

# ── Email (Postmark recommended for Nigerian inbox deliverability) ──
SMTP_HOST=smtp.postmarkapp.com
SMTP_PORT=587
SMTP_USER=YOUR_POSTMARK_API_KEY
SMTP_PASS=YOUR_POSTMARK_API_KEY
EMAIL_FROM=AfriQuote <hello@afriquote.africa>

# ── Payments — AfriQuote platform subscriptions ─────────────────
# Get from: dashboard.paystack.com → Settings → API Keys
PAYSTACK_SECRET_KEY=sk_live_REPLACE_WITH_YOUR_KEY
PAYSTACK_PUBLIC_KEY=pk_live_REPLACE_WITH_YOUR_KEY

# Paystack subscription plan codes (create plans in Paystack dashboard)
# Amount in Kobo: ₦10,000 = 1000000, ₦20,000 = 2000000, ₦50,000 = 5000000
PAYSTACK_PLAN_LITE=PLN_REPLACE_LITE_PLAN_CODE
PAYSTACK_PLAN_PRO=PLN_REPLACE_PRO_PLAN_CODE
PAYSTACK_PLAN_TEAM=PLN_REPLACE_TEAM_PLAN_CODE

# ── App URL (used in email links, payment callbacks) ────────────
APP_URL=https://yourdomain.com

# ── Data storage ────────────────────────────────────────────────
# Default: ./data/ folder (JSON files). Set DATABASE_URL to switch to PostgreSQL.
# DATABASE_URL=postgresql://user:password@host:5432/afriquote
